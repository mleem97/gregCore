## 14. MEMORY MANAGEMENT & STABILITY

### IL2CPP Object Lifetime
```csharp
// UNSAFE ❌
public class BadCache
{
    private IntPtr _cachedPtr;

    public void Cache(Il2CppObjectBase obj)
    {
        _cachedPtr = obj.Pointer;  // Dangerous!
    }

    public void Use()
    {
        Marshal.ReadInt32(_cachedPtr);  // Crash if GC collected obj
    }
}

// SAFE ✅
public class GoodCache
{
    private Il2CppObjectBase _cachedObj;

    public void Cache(Il2CppObjectBase obj)
    {
        _cachedObj = obj;  // Hold the managed wrapper
    }

    public void Use()
    {
        if (_cachedObj == null || _cachedObj.Pointer == IntPtr.Zero)
            return;
        // Safe to use
    }
}
```

### Circular Reference Prevention
```csharp
// WRONG ❌ — Circular ref: Managed → IL2CPP → Managed
public class Bad
{
    private Il2CppPlayer _player;

    public void Subscribe()
    {
        _player.OnCoinChanged += (delta) => HandleCoinChange(delta);
    }
}

// RIGHT ✅ — Use event bus instead
public class Good
{
    public void Subscribe()
    {
        greg.EventBus.Subscribe("greg.PLAYER.CoinChanged", (payload) =>
        {
            HandleCoinChange(payload);
        });
    }
}
```

### String Conversions
```csharp
// IL2CPP string → managed string
Il2CppSystem.String nativeStr = GetNativeString();
string managedStr = nativeStr?.ToString() ?? "";

// managed string → IL2CPP string
string managedStr = "hello";
Il2CppSystem.String nativeStr = (Il2CppSystem.String)(object)managedStr;
```

### GC Pressure
```csharp
// Don't force GC in hot paths
for (int i = 0; i < 1000000; i++)
{
    // Don't call GC.Collect() here!
    ProcessFrame();
}

// Only call GC.Collect() during safe pauses
public override void OnUpdate()
{
    if (Input.GetKeyDown(KeyCode.F12))
    {
        GC.Collect();
        GC.WaitForPendingFinalizers();
    }
}
```

