## 11. GO MODS (FFI VIA CGO)

Go mods are native DLLs using CGO to interface with `GameApiTable`.

### Go SDK Layout
Download `greg-go-sdk.zip` and extract:
```
greg-go-sdk/
├── go.mod
├── greg/
│   ├── api.go          # GameApiTable definitions
│   └── events.go
├── examples/
│   └── hello_mod.go
└── build.sh            # Compilation script
```

### Basic Go Mod Template
```go
// main.go

package main

/*
#include "api.h"
typedef struct {
    uint32_t version;
    int (*RegisterEventHandler)(uint32_t event_id, const char* handler);
    int (*SendNetworkMessage)(const char* recipient, const char* msg_type, const char* payload);
    int64_t (*GetBalance)(const char* player_id);
    int (*AddMoney)(const char* player_id, int64_t amount);
} GameApiTable;
*/
import "C"

import (
    "fmt"
    "unsafe"
)

var api *C.GameApiTable

//export GregInit
func GregInit(apiPtr *C.GameApiTable) {
    if apiPtr == nil {
        return
    }
    if apiPtr.version < 1 {
        return // Incompatible version
    }
    api = apiPtr
    fmt.Println("Mod initialized!")
}

//export GregOnEvent
func GregOnEvent(eventId C.uint32_t, payload *C.char) {
    switch eventId {
    case 1:
        handlePlayerCoinChanged(payload)
    case 2:
        handleServerStatusChanged(payload)
    }
}

func handlePlayerCoinChanged(payload *C.char) {
    fmt.Println("Player coins changed!")
    // Parse payload and handle event
}

func handleServerStatusChanged(payload *C.char) {
    fmt.Println("Server status changed!")
}

//export ModVersion
func ModVersion() *C.char {
    return C.CString("1.0.0")
}

func main() {
    // Dummy main for CGO compilation
}
```

### Compilation
```bash
go build -o my_mod.dll
# Copy to: Data/Mods/my_mod.dll
```

