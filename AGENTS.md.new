## 8. JAVASCRIPT / TYPESCRIPT MODS (JINT)

GregCore uses **Jint 4.8.0** for JavaScript execution.

### Basic JavaScript Mod Template
```javascript
// File: my_mod.js

// Hook subscriptions
greg.on("greg.PLAYER.CoinChanged", (payload) => {
    console.log("Coins changed!");
    console.log(`  From: ${payload.from}`);
    console.log(`  To:   ${payload.to}`);
});

greg.on("greg.UI.PauseMenu.Opened", (payload) => {
    greg.ui.notify("Game paused!");
});

// API access
const balance = greg.economy.getBalance(playerId);
greg.economy.addMoney(playerId, 1000);

const servers = greg.server.getAll();
servers.forEach((server) => {
    console.log(`Server: ${server.id} Status: ${server.status}`);
});

// Network messages
greg.network.sendMessage(recipientId, "GREETING", { text: "Hello!" });

// Persistence
greg.save.persist("mySetting", 42);
const value = greg.save.load("mySetting");
```

### TypeScript Definitions
TypeScript mods require `greg.d.ts`:
```typescript
declare namespace greg {
    interface EventPayload {
        [key: string]: any;
    }

    function on(hookName: string, handler: (payload: EventPayload) => void): void;
    function fire(hookName: string, payload: EventPayload): void;

    namespace economy {
        function getBalance(playerId: string): number;
        function addMoney(playerId: string, amount: number): void;
    }

    namespace ui {
        function notify(message: string): void;
        function showDialog(title: string, message: string, buttons: string[]): Promise<number>;
    }
    // ... more modules
}
```

