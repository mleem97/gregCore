{
  "name": "fmf-hook-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scan repo hooks, merge into fmf_hooks.json, emit wiki MDX and optional codegen.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "hooks:docs": "node dist/index.js --docs",
    "hooks:all": "node dist/index.js --docs --write-registry"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
