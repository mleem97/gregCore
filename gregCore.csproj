<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyName>gregCore</AssemblyName>
    <RootNamespace>gregModLoader</RootNamespace>
    <Authors>MLeeM97</Authors>
    <Version>1.0.0-pre.1</Version>
    <Description>gregCore runtime for Data Center (native + script mod bridges)</Description>
    <NoWarn>CS1701;CS1702</NoWarn>
    <MSBuildWarningsAsMessages>MSB3243;MSB3277</MSBuildWarningsAsMessages>
  </PropertyGroup>

  <PropertyGroup>
    <MelonNet6Dir>$(MSBuildProjectDirectory)\gregLib\references\MelonLoader\net6</MelonNet6Dir>
