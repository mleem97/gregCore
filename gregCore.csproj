  <ItemGroup>
    <Compile Remove="gregMain.cs" />
    <Compile Remove="gregMainCi.cs" />
    <Compile Remove="gregTests\**\*.cs" />
    <Compile Remove="gregModLoader\TestMods\FrameworkDependencyTest.cs" />
    <Compile Remove="**\obj\**\*.cs" />
    <Compile Remove="**\bin\**\*.cs" />
    <None Include="gregMain.cs" />
    <None Include="gregMainCi.cs" />
    <None Include="gregTests\**\*.cs" />
    <None Include="gregModLoader\TestMods\FrameworkDependencyTest.cs" />
    <None Include="gregModLoader\DC2WebBridge.cs" />
    <None Include="gregModLoader\UiModernizer.cs" />
    <None Include="gregModLoader\ModSettingsMenuBridge.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include=".github\copilot-instructions.md" />
    <None Include=".github\workflows\commitlint.yml" />
    <None Include=".github\workflows\dotnet-ci.yml" />
    <None Include="gregScripts\Find-DataCenterPath.ps1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\greg_hooks.json" Condition="Exists('$(MSBuildProjectDirectory)\..\greg_hooks.json')">
      <Link>greg_hooks.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
